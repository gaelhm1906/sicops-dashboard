# Frontend — variables de entorno para desarrollo local
# CRA usa prefijo REACT_APP_ (no VITE_)
# api.js soporta ambos: VITE_GIS_API_URL || REACT_APP_API_URL

# Descomentar para apuntar explícitamente al backend en Render (en producción se usa automáticamente):
# REACT_APP_API_URL=https://sigsobse-backend.onrender.com

# En desarrollo local, api.js detecta localhost y usa http://localhost:3001/api automáticamente.
